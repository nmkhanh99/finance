// Prisma schema — Web Quản lý Tài chính Cá nhân
// Tiền lưu bằng Decimal (KHÔNG dùng float). currency mặc định VND.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----- Người dùng (multi-user) -----
// Đăng nhập bằng username (chưa có mật khẩu). `externalId` để map sau với IdP
// (vd Keycloak `sub`) khi bật bảo mật — không phải đổi schema dữ liệu.
model User {
  id         String   @id @default(cuid())
  username   String   @unique
  externalId String?  @unique
  createdAt  DateTime @default(now())

  accounts      Account[]
  categories    Category[]
  transactions  Transaction[]
  budgets       Budget[]
  holdings      Holding[]
  debts         Debt[]
  goals         Goal[]
  recurrings    RecurringTransaction[]
  netWorthSnaps NetWorthSnapshot[]
  tripGroups    TripGroup[]
}

// ----- Tài khoản & dòng tiền -----

enum AccountType {
  CASH // tiền mặt
  BANK // tài khoản ngân hàng
}

model Account {
  id        String      @id @default(cuid())
  name      String
  type      AccountType
  balance   Decimal     @default(0) @db.Decimal(18, 2)
  currency  String      @default("VND")
  note      String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  transactions  Transaction[]          @relation("AccountTx")
  transfersFrom Transaction[]          @relation("FromAccount")
  recurring     RecurringTransaction[] @relation("RecurringAccount")
  recurringTo   RecurringTransaction[] @relation("RecurringToAccount")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@index([userId])
}

enum TransactionType {
  INCOME // thu
  EXPENSE // chi
  TRANSFER // chuyển giữa các tài khoản
}

model Category {
  id        String          @id @default(cuid())
  name      String
  type      TransactionType // INCOME hoặc EXPENSE
  icon      String?
  createdAt DateTime        @default(now())

  transactions Transaction[]
  budget       Budget?
  recurrings   RecurringTransaction[]

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@index([userId])
}

// Hạn mức chi tiêu hằng tháng cho 1 danh mục (lặp lại mỗi tháng)
model Budget {
  id          String   @id @default(cuid())
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId  String   @unique
  limitAmount Decimal  @db.Decimal(18, 2)
  currency    String   @default("VND")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@index([userId])
}

model Transaction {
  id        String          @id @default(cuid())
  type      TransactionType
  amount    Decimal         @db.Decimal(18, 2)
  date      DateTime // ngày phát sinh
  note      String?
  createdAt DateTime        @default(now())

  account   Account @relation("AccountTx", fields: [accountId], references: [id], onDelete: Cascade)
  accountId String

  // chỉ dùng cho TRANSFER: tài khoản nhận
  toAccount   Account? @relation("FromAccount", fields: [toAccountId], references: [id])
  toAccountId String?

  category   Category? @relation(fields: [categoryId], references: [id])
  categoryId String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  // Liên kết với khoản chi nhóm đã ứng tiền (nếu giao dịch sinh ra từ Trip).
  tripExpense   TripExpense? @relation(fields: [tripExpenseId], references: [id], onDelete: SetNull)
  tripExpenseId String?

  @@index([date])
  @@index([accountId])
  @@index([userId])
  @@index([tripExpenseId])
}

// ----- Đầu tư -----

enum AssetType {
  STOCK // chứng khoán
  CRYPTO // tiền ảo
}

model Holding {
  id        String    @id @default(cuid())
  symbol    String // VD: VNM, BTC
  assetType AssetType
  quantity  Decimal   @db.Decimal(28, 8) // crypto có phần lẻ lớn
  avgCost   Decimal   @db.Decimal(18, 8) // giá vốn trung bình / đơn vị
  currency  String    @default("VND")
  note      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  prices PriceSnapshot[]

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@unique([userId, symbol, assetType])
  @@index([userId])
}

model PriceSnapshot {
  id        String   @id @default(cuid())
  holding   Holding  @relation(fields: [holdingId], references: [id], onDelete: Cascade)
  holdingId String
  price     Decimal  @db.Decimal(18, 8)
  at        DateTime @default(now())

  @@index([holdingId, at])
}

// ----- Nợ / Vay -----

enum DebtInterestType {
  SIMPLE // lãi đơn
  COMPOUND // lãi kép
  AMORTIZING // trả góp đều (annuity)
}

model Debt {
  id           String           @id @default(cuid())
  name         String
  principal    Decimal          @db.Decimal(18, 2) // gốc ban đầu
  interestRate Decimal          @db.Decimal(9, 6) // lãi suất NĂM, dạng thập phân (0.12 = 12%/năm)
  interestType DebtInterestType @default(AMORTIZING)
  termMonths   Int // kỳ hạn (tháng)
  startDate    DateTime
  currency     String           @default("VND")
  note         String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  payments DebtPayment[]

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@index([userId])
}

model DebtPayment {
  id        String   @id @default(cuid())
  debt      Debt     @relation(fields: [debtId], references: [id], onDelete: Cascade)
  debtId    String
  amount    Decimal  @db.Decimal(18, 2) // tổng trả kỳ này
  principal Decimal  @db.Decimal(18, 2) // phần gốc
  interest  Decimal  @db.Decimal(18, 2) // phần lãi
  date      DateTime
  createdAt DateTime @default(now())

  @@index([debtId, date])
}

// ----- Mục tiêu -----

model Goal {
  id           String   @id @default(cuid())
  name         String
  targetAmount Decimal  @db.Decimal(18, 2)
  currentSaved Decimal  @default(0) @db.Decimal(18, 2)
  targetDate   DateTime
  currency     String   @default("VND")
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@index([userId])
}

// ----- Chia tiền nhóm (đi chơi) — độc lập với tài chính cá nhân -----

model TripGroup {
  id        String        @id @default(cuid())
  name      String
  note      String?
  createdAt DateTime      @default(now())
  members   TripMember[]
  expenses  TripExpense[]

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@index([userId])
}

model TripMember {
  id        String    @id @default(cuid())
  group     TripGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId   String
  name      String
  isSelf    Boolean   @default(false) // thành viên này là chủ tài khoản (bạn) — tối đa 1/nhóm
  createdAt DateTime  @default(now())

  paidExpenses TripExpense[]      @relation("ExpensePayer")
  shares       TripExpenseShare[]

  @@index([groupId])
}

enum SplitType {
  EQUAL // chia đều
  CUSTOM // tùy chỉnh số tiền mỗi người
}

model TripExpense {
  id          String     @id @default(cuid())
  group       TripGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId     String
  description String // nội dung chi phí (bắt buộc)
  amount      Decimal    @db.Decimal(18, 2)
  currency    String     @default("VND") // tiền tệ của khoản chi (amount & shares theo mã này)
  date        DateTime
  splitType   SplitType  @default(EQUAL)
  payer       TripMember @relation("ExpensePayer", fields: [payerId], references: [id])
  payerId     String
  createdAt   DateTime   @default(now())

  shares             TripExpenseShare[]
  linkedTransactions Transaction[] // giao dịch cá nhân sinh ra khi bạn ứng tiền

  @@index([groupId])
}

// Tỷ giá quy đổi về tiền tệ gốc (base = VND). rate = số VND cho 1 đơn vị `code`. VND có rate = 1.
model ExchangeRate {
  code      String   @id // "VND", "USD", ...
  rate      Decimal  @db.Decimal(18, 6)
  updatedAt DateTime @updatedAt
}

enum RecurrenceFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

// Mẫu giao dịch định kỳ — tự sinh Transaction theo lịch (lương, tiền nhà, subscription...).
model RecurringTransaction {
  id          String              @id @default(cuid())
  type        TransactionType
  amount      Decimal             @db.Decimal(18, 2)
  account     Account             @relation("RecurringAccount", fields: [accountId], references: [id], onDelete: Cascade)
  accountId   String
  toAccount   Account?            @relation("RecurringToAccount", fields: [toAccountId], references: [id])
  toAccountId String?
  category    Category?           @relation(fields: [categoryId], references: [id])
  categoryId  String?
  note        String?
  frequency   RecurrenceFrequency
  startDate   DateTime
  nextRun     DateTime // thời điểm sinh giao dịch kế tiếp
  endDate     DateTime?
  active      Boolean             @default(true)
  createdAt   DateTime            @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@index([active, nextRun])
  @@index([userId])
}

// Snapshot tài sản ròng tại 1 thời điểm (1 bản/ngày) để vẽ Net Worth theo thời gian.
model NetWorthSnapshot {
  id          String   @id @default(cuid())
  date        DateTime @db.Date // chuẩn hoá theo ngày
  totalCash   Decimal  @db.Decimal(18, 2)
  totalInvest Decimal  @db.Decimal(18, 2)
  totalDebt   Decimal  @db.Decimal(18, 2)
  netWorth    Decimal  @db.Decimal(18, 2)
  createdAt   DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@unique([userId, date])
}

// Mỗi dòng = số tiền 1 người phải chịu trong 1 chi phí
model TripExpenseShare {
  id        String      @id @default(cuid())
  expense   TripExpense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  expenseId String
  member    TripMember  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  memberId  String
  amount    Decimal     @db.Decimal(18, 2)

  @@unique([expenseId, memberId])
  @@index([memberId])
}
