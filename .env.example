# ===== Cấu hình cho Docker Compose =====
# Copy thành .env (đã gitignore) rồi chỉnh nếu cần. Không bắt buộc — có giá trị mặc định.

# Postgres
POSTGRES_USER=finance
POSTGRES_PASSWORD=finance
POSTGRES_DB=finance

# Cổng mở ra máy host
DB_PORT=5432
WEB_PORT=3000

# ===== Khi chạy LOCAL (không Docker), Prisma dùng DATABASE_URL này =====
# DATABASE_URL="postgresql://khanhnm@localhost:5432/postgres?schema=finance"

# ===== Authentication =====
# Đăng nhập BẮT BUỘC bằng username (chưa có mật khẩu — bảo mật IdP/Keycloak để dành sau).
# AUTH_SECRET: chuỗi ngẫu nhiên dài để KÝ cookie phiên (HMAC). Nên đặt khi deploy
# (bỏ trống -> dùng secret mặc định KHÔNG an toàn, chỉ hợp chạy local).
# AUTH_SECRET=chuoi-bi-mat-ngau-nhien-dai
# CRON_SECRET: cho phép cron gọi /api/* bằng ?key=... (job chạy đa người dùng).
# CRON_SECRET=khoa-cron-ngau-nhien
