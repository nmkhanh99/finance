# ===== Cấu hình cho Docker Compose =====
# Copy thành .env (đã gitignore) rồi chỉnh nếu cần. Không bắt buộc — có giá trị mặc định.

# Postgres
POSTGRES_USER=finance
POSTGRES_PASSWORD=finance
POSTGRES_DB=finance

# Cổng mở ra máy host
DB_PORT=5432
WEB_PORT=3000

# ===== Khi chạy LOCAL (không Docker), Prisma dùng DATABASE_URL này =====
# DATABASE_URL="postgresql://khanhnm@localhost:5432/postgres?schema=finance"

# ===== Authentication (tuỳ chọn) =====
# Đặt AUTH_PASSWORD để BẬT đăng nhập (bảo vệ dữ liệu tài chính). Bỏ trống = tắt auth.
# AUTH_PASSWORD=doi-mat-khau-cua-ban
# AUTH_SECRET dùng để ký cookie phiên (chuỗi ngẫu nhiên dài). Nên đặt khi bật auth.
# AUTH_SECRET=chuoi-bi-mat-ngau-nhien-dai
# CRON_SECRET: cho phép cron gọi /api/* bằng ?key=... khi auth bật.
# CRON_SECRET=khoa-cron-ngau-nhien
